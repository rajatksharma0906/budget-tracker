# ===========================================
# MySQL – copy to .env and update values
#   cp .env.example .env
# ===========================================

# MySQL host (use localhost or 127.0.0.1 for local)
MYSQL_HOST=localhost

# MySQL port (default 3306)
MYSQL_PORT=3306

# MySQL user (e.g. root or a dedicated app user)
MYSQL_USER=root

# MySQL password (leave empty if no password)
MYSQL_PASSWORD=

# Database name (created by npm run db:create if missing)
MYSQL_DATABASE=budget_tracker

