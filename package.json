{
  "name": "budget-tracker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "npx nest build",
    "start": "node dist/src/main",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/src/main",
    "lint": "eslint \"{src,lib,scripts}/**/*.ts\"",
    "db:create": "node scripts/create-database.js",
    "db:migrate": "node scripts/run-migrations.js",
    "db:setup": "npm run db:create && npm run db:migrate",
    "db:test": "node scripts/test-connection.js"
  },
  "dependencies": {
    "@nestjs/cli": "^10.0.0",
    "dotenv": "^16.4.5",
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/swagger": "^7.0.0",
    "bcryptjs": "^2.4.3",
    "date-fns": "^3.6.0",
    "mysql2": "^3.11.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "typescript": "^5.5.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.12",
    "eslint": "^8.57.0"
  }
}
